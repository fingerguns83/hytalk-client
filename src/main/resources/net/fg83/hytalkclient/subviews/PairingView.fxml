                        </Label>
                     </children>
                  </Pane>
                  <HBox alignment="CENTER" prefHeight="48.0" prefWidth="200.0">
                     <children>
                        <StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="48.0" prefWidth="140.0" scaleX="0.8" scaleY="0.8" scaleZ="0.8" styleClass="wrapper" stylesheets="@../../../../assets/stylesheets/ActionButton.css">
                           <Button focusTraversable="false" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" onAction="#handleCancel" prefHeight="46.0" prefWidth="140.0" styleClass="action-button">
