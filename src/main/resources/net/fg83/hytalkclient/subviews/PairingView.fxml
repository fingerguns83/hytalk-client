<AnchorPane fx:id="PAIRING_ROOT" focusTraversable="true" prefHeight="400.0" prefWidth="400.0" style="-fx-background-color: #353434;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.fg83.hytalkclient.ui.controller.PairingController">
   <children>
      <VBox alignment="TOP_CENTER" prefHeight="400.0" prefWidth="400.0">
         <children>
            <Pane prefHeight="100.0" prefWidth="400.0">
               <children>
                  <ImageView disable="true" fitHeight="150.0" fitWidth="150.0" layoutX="135.0" layoutY="-5.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../../../../assets/images/hytalk_logo_transparent.png" />
                     </image>
                  </ImageView>
               </children>
            </Pane>
            <VBox prefHeight="300.0" prefWidth="400.0">
               <children>
                  <Pane prefHeight="186.0" prefWidth="400.0">
                     <children>
                        <Label fx:id="PAIRING_CODE_LABEL" alignment="CENTER" contentDisplay="CENTER" layoutY="71.0" maxWidth="400.0" minWidth="400.0" prefWidth="400.0" textFill="#8a8a8a">
                           <font>
                              <Font name="Bona Nova SC Bold" size="48.0" />
                           </font>
                        </Label>
                        <Label alignment="CENTER" contentDisplay="CENTER" layoutX="77.0" layoutY="140.0" text="Enter code on server (&quot;/hytalk pair &lt;code&gt;&quot;)" textFill="#aaaaaa">
